# MediTriage Environment Configuration
# =====================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app works WITHOUT an API key using the built-in rule-based triage engine.
# To enable AI-powered triage with Google Gemini, get a free key from:
# https://aistudio.google.com/apikey

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
PORT=3000
